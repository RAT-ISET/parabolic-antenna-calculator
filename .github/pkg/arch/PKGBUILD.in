pkgname=@PROJECT_NAME@
pkgver=@PROJECT_VERSION@
pkgrel=@PROJECT_RELEASE@
arch=('x86_64')

pkgdesc="@PROJECT_DESCRIPTION@"
license=('MIT')

package() {
    cp -a "$startdir/install/." "$pkgdir/"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm655 LICENSE "$pkgdir/usr/licenses/$pkgname/LICENSE"
}
