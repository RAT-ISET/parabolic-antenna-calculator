include(CPack)

set(CPACK_PACKAGE_NAME ${PROJECT_NAME})
set(CPACK_PACKAGE_VERSION ${PROJECT_VERSION})
set(CPACK_PACKAGE_VENDOR "ISET")
set(CPACK_PACKAGE_CONTACT "ratiset@outlook.com")
set(CPACK_DEBIAN_PACKAGE_MAINTAINER "Team ISET")
set(CPACK_DEBIAN_PACKAGE_DEPENDS "")
set(CPACK_RPM_PACKAGE_LICENSE "MIT")
set(CPACK_OUTPUT_FILE_PREDIX "${CMAKE_SOURCE_DIR}/dist")

if (WIN32)
    set(CPACK_GENERATOR "NSIS;ZIP;WIX")
    set(CPACK_WIX_VERSION 3)
    set(CPACK_WIX_UPGRADE_GUID "" CACHE STRING "WiX Upgrade GUID")
elseif (APPLE)
    set(CPACK_GENERATOR "DragNDrop;TGZ")
elseif (UNIX)
    set(CPACK_GENERATOR "TGZ;DEB;RPM")
endif ()
